{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rootsmith/repos",
  "title": "GitHub repo registry",
  "description": "Every owned repo not claimed by a venture manifest, with an explicit disposition (I1 extended to repos).",
  "type": "object",
  "additionalProperties": false,
  "required": ["repos"],
  "properties": {
    "repos": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "disposition"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
          "disposition": { "enum": ["keep", "archive", "ignore", "unassigned"] },
          "note": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
